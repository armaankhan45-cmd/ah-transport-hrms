{
  "name": "ah-transport-hrms-backend",
  "version": "1.0.1",
  "description": "A.H. Transport Co. - Enterprise HRMS Backend – Office-Only + Admin Remote",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": { "node": ">=18.0.0 <25.0.0" },
  "scripts": {
    "start": "node src/server.js",
    "start:unix": "NODE_ENV=production node src/server.js",
    "start:win": "set NODE_ENV=production&& node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:unix": "NODE_ENV=development nodemon src/server.js",
    "dev:win": "set NODE_ENV=development&& nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "postinstall": "node -e \"try{require('better-sqlite3')}catch(e){console.log('better-sqlite3 native build – if fails use Node 20 LTS')}\""
  },
  "dependencies": {
    "express": "^4.19.2",
    "better-sqlite3": "^11.9.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "dotenv": "^16.4.5",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "pdfkit": "^0.14.0",
    "exceljs": "^4.4.0",
    "multer": "^1.4.5-lts.1",
    "date-fns": "^3.3.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "eslint": "^8.57.0"
  },
  "license": "UNLICENSED",
  "private": true,
  "overrides": {
    "better-sqlite3": "$better-sqlite3"
  }
}
